@model Project.Application.ViewModels.CategoryIndexViewModel

<div class="row g-4">
    @foreach (var category in Model.FilteredCategories)
    {
        <div class="col-md-3">
            <div class="card h-100 border-0 shadow-sm p-3 text-center">
                <i class="bi bi-bookmark-fill text-primary fs-2 mb-2"></i>
                <h5 class="fw-bold">@category.Name</h5>
                <p class="text-muted">@category.BookCount Books available</p>
                <a href="/Books?categoryId=@category.Id" class="btn btn-sm btn-primary mt-auto">Browse</a>
            </div>
        </div>
    }
</div>