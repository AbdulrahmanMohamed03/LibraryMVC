@using Project.Application.ViewModels.BorrowingRecord
@model IEnumerable<BorrowingRecordVM>

@{
    ViewData["Title"] = "Pending Borrow Requests";
}

<h2>Pending Borrow Requests</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>#</th>
            <th>Borrower</th>
            <th>Book</th>
            <th>Requested At</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.BorrowerName</td>
                <td>@item.BookTitle</td>
                <td>@item.RequestedAt.ToString("yyyy-MM-dd HH:mm")</td>

                <td>
                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-info btn-sm">
                        Details
                    </a>

                    <form asp-action="Approve" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@item.Id" />

                        <button type="submit" class="btn btn-success btn-sm">
                            Approve
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>