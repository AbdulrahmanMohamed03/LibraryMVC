


@model Project.Application.ViewModels.Account.RegisterVM
@{
    ViewData["Title"] = "Create Account";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="min-height:88vh;display:flex;align-items:center;justify-content:center;background:var(--cream);padding:2rem 1rem">
    <div style="width:100%;max-width:480px">

        <div style="text-align:center;margin-bottom:2.5rem">
            <a asp-controller="Home" asp-action="Index"
               style="font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--ink);text-decoration:none">
                MAK<span style="color:var(--gold)">TBA</span>
            </a>
            <p style="font-size:0.72rem;letter-spacing:2px;text-transform:uppercase;color:var(--ash);margin-top:0.5rem">
                Join the Library
            </p>
        </div>

        <div style="background:var(--white);border:1px solid var(--border);padding:2.5rem">

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All"
                     style="background:#fdf4f4;border:1px solid #f5a0a0;border-left:4px solid var(--red-soft);padding:0.85rem 1rem;font-size:0.85rem;color:#7a1f1f;margin-bottom:1.5rem">
                </div>
            }

            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                <div style="margin-bottom:1.1rem">
                    <label asp-for="FullName" class="lib-form-label">Full Name</label>
                    <input asp-for="FullName" class="lib-form-control" placeholder="Jane Austen" />
                    <span asp-validation-for="FullName" style="font-size:0.75rem;color:var(--red-soft);display:block;margin-top:4px"></span>
                </div>

                <div style="margin-bottom:1.1rem">
                    <label asp-for="NationalId" class="lib-form-label">National ID</label>
                    <input asp-for="NationalId" class="lib-form-control" placeholder="e.g. 29901010123456" />
                    <span asp-validation-for="NationalId" style="font-size:0.75rem;color:var(--red-soft);display:block;margin-top:4px"></span>
                </div>

                <div style="margin-bottom:1.1rem">
                    <label asp-for="Email" class="lib-form-label">Email Address</label>
                    <input asp-for="Email" class="lib-form-control" placeholder="you@example.com" />
                    <span asp-validation-for="Email" style="font-size:0.75rem;color:var(--red-soft);display:block;margin-top:4px"></span>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.1rem">
                    <div>
                        <label asp-for="Password" class="lib-form-label">Password</label>
                        <input asp-for="Password" class="lib-form-control" type="password" placeholder="••••••••" />
                        <span asp-validation-for="Password" style="font-size:0.75rem;color:var(--red-soft);display:block;margin-top:4px"></span>
                    </div>
                    <div>
                        <label asp-for="ConfirmPassword" class="lib-form-label">Confirm</label>
                        <input asp-for="ConfirmPassword" class="lib-form-control" type="password" placeholder="••••••••" />
                        <span asp-validation-for="ConfirmPassword" style="font-size:0.75rem;color:var(--red-soft);display:block;margin-top:4px"></span>
                    </div>
                </div>

                <div style="background:var(--cream);border:1px solid var(--border);padding:0.85rem 1rem;font-size:0.78rem;color:var(--ash);margin-bottom:1.75rem;line-height:1.6">
                    <i class="fa-solid fa-circle-info me-2" style="color:var(--gold)"></i>
                    By registering you agree to library membership terms. A subscription plan is required to borrow books.
                </div>

                <button type="submit" class="btn-ink" style="width:100%;text-align:center">
                    Create Library Account
                </button>
            </form>
        </div>

        <div style="text-align:center;margin-top:1.5rem;font-size:0.82rem;color:var(--ash)">
            Already a member?
            <a asp-controller="Account" asp-action="Login"
               style="color:var(--gold);font-weight:600;margin-left:4px">Sign In</a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}