@model Project.Application.ViewModels.User.CreateLibrarianVM

@{
    ViewData["Title"] = "Create Librarian";
}

<div class="container py-5" style="max-width: 750px;">

    <div style="margin-bottom: 2.5rem;">
        <span class="section-eyebrow">Onboarding Control</span>
        <h2 class="section-title" style="font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; font-weight: 700; color: var(--ink); margin: 0;">
            Register New <strong>Librarian</strong>
        </h2>
        <div style="width: 48px; height: 2px; background: var(--gold); margin-top: 0.75rem;"></div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-booksaw success mb-4" style="background: #e6f4ea; color: #1a6832; padding: 1rem; border-left: 4px solid #1a6832; font-size: 0.88rem;">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
        </div>
    }

    <div class="booksaw-card" style="background: var(--white); border: 1px solid var(--border); padding: 3rem; box-shadow: 0 12px 35px rgba(0,0,0,0.03);">

        <form asp-action="CreateLibrarian" method="post">

            <div asp-validation-summary="All" class="text-danger mb-4" style="font-size: 0.88rem; list-style-type: none; padding-left: 0;"></div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <label asp-for="FullName" style="display: block; font-size: .68rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--ash); margin-bottom: .5rem;"></label>
                    <input asp-for="FullName" class="form-control" style="border-radius: 0; border: 1px solid var(--border); padding: 0.75rem 1rem; font-size: 0.88rem; color: var(--ink); outline: none;" placeholder="e.g. John Doe" />
                    <span asp-validation-for="FullName" class="text-danger" style="font-size: 0.8rem; display: block; mt-1;"></span>
                </div>

                <div class="col-md-6 mb-4">
                    <label asp-for="NationalId" style="display: block; font-size: .68rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--ash); margin-bottom: .5rem;"></label>
                    <input asp-for="NationalId" class="form-control" style="border-radius: 0; border: 1px solid var(--border); padding: 0.75rem 1rem; font-size: 0.88rem; color: var(--ink); outline: none; font-family: monospace;" placeholder="Unique Identification Number" />
                    <span asp-validation-for="NationalId" class="text-danger" style="font-size: 0.8rem; display: block; mt-1;"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <label asp-for="Email" style="display: block; font-size: .68rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--ash); margin-bottom: .5rem;"></label>
                    <input asp-for="Email" class="form-control" style="border-radius: 0; border: 1px solid var(--border); padding: 0.75rem 1rem; font-size: 0.88rem; color: var(--ink); outline: none;" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="text-danger" style="font-size: 0.8rem; display: block; mt-1;"></span>
                </div>

                <div class="col-md-6 mb-4">
                    <label asp-for="UserName" style="display: block; font-size: .68rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--ash); margin-bottom: .5rem;"></label>
                    <input asp-for="UserName" class="form-control" style="border-radius: 0; border: 1px solid var(--border); padding: 0.75rem 1rem; font-size: 0.88rem; color: var(--ink); outline: none;" placeholder="Choose system handle" />
                    <span asp-validation-for="UserName" class="text-danger" style="font-size: 0.8rem; display: block; mt-1;"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <label asp-for="Password" style="display: block; font-size: .68rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--ash); margin-bottom: .5rem;"></label>
                    <input asp-for="Password" type="password" class="form-control" style="border-radius: 0; border: 1px solid var(--border); padding: 0.75rem 1rem; font-size: 0.88rem; color: var(--ink); outline: none;" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger" style="font-size: 0.8rem; display: block; mt-1;"></span>
                </div>

                <div class="col-md-6 mb-4">
                    <label asp-for="ConfirmPassword" style="display: block; font-size: .68rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--ash); margin-bottom: .5rem;"></label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" style="border-radius: 0; border: 1px solid var(--border); padding: 0.75rem 1rem; font-size: 0.88rem; color: var(--ink); outline: none;" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size: 0.8rem; display: block; mt-1;"></span>
                </div>
            </div>

            <div class="mb-5">
                <label asp-for="RoleName" style="display: block; font-size: .68rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--ash); margin-bottom: .5rem;"></label>
                <select asp-for="RoleName" asp-items="ViewBag.Roles" class="form-select" style="border-radius: 0; border: 1px solid var(--border); padding: 0.75rem 1rem; font-size: 0.88rem; color: var(--ink); outline: none;">
                    <option value="">-- Choose System Access Tier --</option>
                </select>
                <span asp-validation-for="RoleName" class="text-danger" style="font-size: 0.8rem; display: block; mt-1;"></span>
            </div>

            <div class="d-flex gap-2 align-items-center pt-2">
                <button type="submit" class="btn-cd" style="flex: 1; padding: .8rem 0; font-size: .68rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; text-align: center; text-decoration: none; background: var(--ink); color: var(--white); border: 1px solid var(--ink); transition: all .2s; border-radius: 0; cursor: pointer;">
                    <i class="fa-solid fa-plus me-2"></i>Create Profile Record
                </button>
                <a asp-action="ManageLibrarians" class="btn-cr" style="padding: .8rem 1.5rem; font-size: .68rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; text-decoration: none; background: transparent; color: var(--ash); border: 1px solid var(--border); transition: all .2s; border-radius: 0; text-align: center;">
                    Cancel
                </a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}