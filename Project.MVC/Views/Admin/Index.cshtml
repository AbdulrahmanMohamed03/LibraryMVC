

@using Project.Application.ViewModels.Admin
@model AdminDashboardVM

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .dash-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        margin-bottom: 2rem;
    }

    .stat-tile-inner {
        background: var(--white);
        padding: 1.75rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        transition: background 0.2s;
    }

        .stat-tile-inner:hover {
            background: #faf9f6;
        }

    .tile-icon-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .tile-icon {
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    .tile-val {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.6rem;
        font-weight: 700;
        color: var(--ink);
        line-height: 1;
    }

    .tile-lbl {
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--ash);
    }

    .tile-sub {
        font-size: 0.72rem;
        color: var(--gold);
        margin-top: 2px;
    }

    .activity-panel {
        background: var(--white);
        border: 1px solid var(--border);
    }

    .panel-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .panel-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.2rem;
        font-weight: 600;
        margin: 0;
    }

    .panel-body {
        padding: 0;
    }

    .activity-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #f5f3ef;
    }

        .activity-row:last-child {
            border-bottom: none;
        }

    .activity-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .dot-gold {
        background: var(--gold);
    }

    .dot-green {
        background: #27ae60;
    }

    .dot-red {
        background: #c0392b;
    }

    .dot-blue {
        background: #2980b9;
    }

    .activity-text {
        flex: 1;
        font-size: 0.85rem;
        color: var(--ink-soft);
    }

    .activity-value {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--ink);
    }

    .quick-actions {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0;
        background: var(--border);
        border: 1px solid var(--border);
    }

    .qa-btn {
        background: var(--white);
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.85rem;
        text-decoration: none;
        color: var(--ink);
        transition: background 0.2s;
    }

        .qa-btn:hover {
            background: #faf9f6;
            color: var(--gold);
        }

        .qa-btn i {
            font-size: 1rem;
            color: var(--gold);
            width: 20px;
        }

        .qa-btn span {
            font-size: 0.78rem;
            font-weight: 600;
            letter-spacing: 0.5px;
        }
</style>

<!-- STAT TILES -->
<div class="dash-grid">

    <a href="@Url.Action("Index", "Books")" class="text-decoration-none" style="display:contents">
        <div class="stat-tile-inner">
            <div class="tile-icon-row">
                <div class="tile-val">@Model.BooksCount</div>
                <div class="tile-icon" style="background:var(--gold-light);">
                    <i class="fa-solid fa-books" style="color:var(--gold-dark)"></i>
                </div>
            </div>
            <div class="tile-lbl">Total Books</div>
        </div>
    </a>

    <a href="@Url.Action("Pending", "BorrowingRecords")" class="text-decoration-none" style="display:contents">
        <div class="stat-tile-inner">
            <div class="tile-icon-row">
                <div class="tile-val">@Model.PendingBorrowsCount</div>
                <div class="tile-icon" style="background:#fff8e1;">
                    <i class="fa-solid fa-hourglass-half" style="color:#d4a017"></i>
                </div>
            </div>
            <div class="tile-lbl">Pending Requests</div>
            @if (Model.PendingBorrowsCount > 0)
            {
                <div class="tile-sub"><i class="fa-solid fa-triangle-exclamation me-1"></i>Needs approval</div>
            }
        </div>
    </a>

    <a href="@Url.Action("Index", "Reservations")" class="text-decoration-none" style="display:contents">
        <div class="stat-tile-inner">
            <div class="tile-icon-row">
                <div class="tile-val">@Model.ReservationsCount</div>
                <div class="tile-icon" style="background:#fdecea;">
                    <i class="fa-solid fa-bookmark" style="color:#c0392b"></i>
                </div>
            </div>
            <div class="tile-lbl">Reservations</div>
            @if (Model.ReadyReservationsCount > 0)
            {
                <div class="tile-sub"><i class="fa-solid fa-circle-check me-1"></i>@Model.ReadyReservationsCount ready for pickup</div>
            }
        </div>
    </a>

    <a href="@Url.Action("Index", "Transaction")" class="text-decoration-none" style="display:contents">
        <div class="stat-tile-inner">
            <div class="tile-icon-row">
                <div class="tile-val">$@Model.TotalIncome.ToString("N0")</div>
                <div class="tile-icon" style="background:#e8f5e9;">
                    <i class="fa-solid fa-dollar-sign" style="color:#27ae60"></i>
                </div>
            </div>
            <div class="tile-lbl">Total Income</div>
        </div>
    </a>

    <a href="@Url.Action("Index", "Category")" class="text-decoration-none" style="display:contents">
        <div class="stat-tile-inner">
            <div class="tile-icon-row">
                <div class="tile-val">@Model.CategoriesCount</div>
                <div class="tile-icon" style="background:#e3f2fd;">
                    <i class="fa-solid fa-tags" style="color:#2980b9"></i>
                </div>
            </div>
            <div class="tile-lbl">Categories</div>
        </div>
    </a>

    @if (User.IsInRole("Admin"))
    {
        <a href="@Url.Action("ManageLibrarians", "Admin")" class="text-decoration-none" style="display:contents">
            <div class="stat-tile-inner">
                <div class="tile-icon-row">
                    <div class="tile-val">@Model.LibrariansCount</div>
                    <div class="tile-icon" style="background:#f3e5f5;">
                        <i class="fa-solid fa-user-tie" style="color:#7b1fa2"></i>
                    </div>
                </div>
                <div class="tile-lbl">Librarians</div>
            </div>
        </a>
    }

</div>

<!-- LOWER ROW -->
<div class="row g-4">

    <!-- ACTIVITY SNAPSHOT -->
    <div class="col-lg-7">
        <div class="activity-panel">
            <div class="panel-header">
                <h3 class="panel-title">System Overview</h3>
                <span style="font-size:0.7rem;letter-spacing:1px;text-transform:uppercase;color:var(--ash)">
                    @DateTime.Now.ToString("MMM dd, yyyy")
                </span>
            </div>
            <div class="panel-body">
                <div class="activity-row">
                    <div class="activity-dot dot-gold"></div>
                    <div class="activity-text">Books in the catalog</div>
                    <div class="activity-value">@Model.BooksCount</div>
                </div>
                <div class="activity-row">
                    <div class="activity-dot dot-blue"></div>
                    <div class="activity-text">Reservation queue entries</div>
                    <div class="activity-value">@Model.ReservationsCount</div>
                </div>
                <div class="activity-row">
                    <div class="activity-dot dot-green"></div>
                    <div class="activity-text">Ready for pickup</div>
                    <div class="activity-value">@Model.ReadyReservationsCount</div>
                </div>
                <div class="activity-row">
                    <div class="activity-dot dot-red"></div>
                    <div class="activity-text">Pending borrow approval</div>
                    <div class="activity-value">@Model.PendingBorrowsCount</div>
                </div>
                <div class="activity-row">
                    <div class="activity-dot dot-gold"></div>
                    <div class="activity-text">Total library income recorded</div>
                    <div class="activity-value">$@Model.TotalIncome.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- QUICK ACTIONS -->
    <div class="col-lg-5">
        <div style="margin-bottom:1rem">
            <span class="section-eyebrow">Shortcuts</span>
            <h3 style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;margin:0">
                Quick Actions
            </h3>
        </div>

        <div class="quick-actions">
            <a asp-controller="Books" asp-action="Create" class="qa-btn">
                <i class="fa-solid fa-plus"></i>
                <span>Add New Book</span>
            </a>
            <a asp-controller="BorrowingRecords" asp-action="Pending" class="qa-btn">
                <i class="fa-solid fa-check-double"></i>
                <span>Approve Borrows</span>
            </a>
            <a asp-controller="Reservations" asp-action="Index" class="qa-btn">
                <i class="fa-solid fa-list-check"></i>
                <span>Manage Queue</span>
            </a>
            <a asp-controller="Author" asp-action="Create" class="qa-btn">
                <i class="fa-solid fa-feather"></i>
                <span>Add Author</span>
            </a>
            <a asp-controller="Category" asp-action="Create" class="qa-btn">
                <i class="fa-solid fa-tag"></i>
                <span>Add Category</span>
            </a>
            <a asp-controller="Transaction" asp-action="Index" class="qa-btn">
                <i class="fa-solid fa-receipt"></i>
                <span>View Transactions</span>
            </a>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div style="margin-top:1.5rem">
                <div class="quick-actions">
                    <a asp-controller="Admin" asp-action="CreateLibrarian" class="qa-btn">
                        <i class="fa-solid fa-user-plus"></i>
                        <span>Add Librarian</span>
                    </a>
                    <a asp-controller="Admin" asp-action="ManageRoles" class="qa-btn">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Manage Roles</span>
                    </a>
                </div>
            </div>
        }
    </div>

</div>
