    <div class="book-flow-container footer-flow-mid">
        <div class="book-flow-track">
            @foreach (var book in catalogBooks)
            {
                <div class="flow-book-item" style="width: 80px; height: 115px;">
                    @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                    {
                        <img src="@book.CoverImageUrl" alt="Flowing Cover" />
                    }
                    else
                    {

                        <div class="flow-book-placeholder"><i class="fa-solid fa-book"></i></div>
                    }
                </div>
            }
        </div>
        <div class="book-flow-track" aria-hidden="true">
            @foreach (var book in catalogBooks)
            {
                <div class="flow-book-item" style="width: 80px; height: 115px;">
                    @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                    {
                        <img src="@book.CoverImageUrl" alt="Flowing Cover" />
                    }
                    else
                    {

                        <div class="flow-book-placeholder"><i class="fa-solid fa-book"></i></div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="container text-center">
        <h2>Ready to Start<br><strong>Reading?</strong></h2>
        <p>Join thousands of readers who trust Bibliotheca to guide their literary journey.</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
            <a asp-controller="Books" asp-action="Index" class="btn-gold">Explore Full Catalog</a>
            @if (User.Identity?.IsAuthenticated != true)
            {
                <a asp-controller="Account" asp-action="Register" class="btn-ghost"
