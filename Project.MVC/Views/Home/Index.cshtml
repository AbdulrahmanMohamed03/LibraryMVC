@section Scripts {
    <script>
        (function () {
            function filterCards(catId, btn) {
                document.querySelectorAll('.cat-nav-btn').forEach(t => t.classList.remove('active'));
                if (btn) btn.classList.add('active');
                else {
                    const f = document.querySelector(`.cat-nav-btn[data-cid="${catId}"]`);
                    if (f) f.classList.add('active');
                }
                document.querySelectorAll('#home-grid .hgi').forEach(c => {
                    c.style.display = (catId === 'all' || c.dataset.cat === String(catId)) ? '' : 'none';
                });
                if (window.innerWidth < 992) {
                    const sec = document.getElementById('popular');
                    if (sec) sec.scrollIntoView({ behavior: 'smooth' });
                }
            }
            window.filterCards = filterCards;
        })();
    </script>
}