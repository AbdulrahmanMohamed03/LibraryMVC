@model Project.Application.ViewModels.Reservation.PlaceReservationViewModel
@{
    ViewData["Title"] = "Confirm Reservation";
}

<style>
    .confirm-card {
        max-width: 520px;
        margin: 40px auto;
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 10px;
        padding: 36px 40px;
        box-shadow: 0 2px 12px rgba(0,0,0,.07);
    }

    h2 {
        margin-bottom: 4px;
    }

    hr {
        border: none;
        border-top: 1px solid #ddd;
        margin-bottom: 24px;
    }

    .book-preview {
        display: flex;
        gap: 20px;
        align-items: flex-start;
        margin-bottom: 24px;
    }

        .book-preview img {
            width: 80px;
            border-radius: 6px;
            border: 1px solid #ddd;
        }

        .book-preview .no-img {
            width: 80px;
            height: 110px;
            background: #f0f0f0;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            color: #aaa;
        }

    .queue-badge {
        background: #fff3cd;
        border: 1px solid #ffc107;
        border-radius: 8px;
        padding: 12px 16px;
        margin-bottom: 20px;
        font-size: 14px;
        color: #856404;
    }

        .queue-badge strong {
            font-size: 22px;
        }

    .info-row {
        font-size: 14px;
        color: #555;
        margin-bottom: 8px;
    }

        .info-row span {
            font-weight: 600;
            color: #333;
        }

    .actions {
        display: flex;
        gap: 12px;
        margin-top: 24px;
    }

    .btn {
        padding: 10px 24px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        text-decoration: none;
        font-size: 14px;
    }

    .btn-primary {
        background: #1565c0;
        color: #fff;
    }

    .btn-secondary {
        background: #9e9e9e;
        color: #fff;
    }

    .btn:hover {
        opacity: .88;
    }

    .rules-note {
        font-size: 12px;
        color: #999;
        margin-top: 16px;
        line-height: 1.6;
    }
</style>

<div class="confirm-card">
    <h2>Confirm Your Reservation</h2>
    <hr />

    <div class="book-preview">
        @if (!string.IsNullOrEmpty(Model.BookCoverUrl))
        {
            <img src="@Model.BookCoverUrl" alt="@Model.BookTitle" />
        }
        else
        {
            <div class="no-img">No Cover</div>
        }
        <div>
            <div style="font-size:18px;font-weight:700;margin-bottom:4px">@Model.BookTitle</div>
            <div style="color:#777;font-size:14px">@Model.BookAuthor</div>
            <div class="info-row" style="margin-top:10px">
                Borrow Fee: <span>@Model.BorrowFee.ToString("C")</span>
            </div>
        </div>
    </div>

    <div class="queue-badge">
        📋 You will be <strong>#@Model.QueuePosition</strong> in the queue.
        You'll be notified when it's your turn to pick up.
    </div>

    <div class="info-row">All copies are currently checked out.</div>
    <div class="info-row">
        Once your copy is ready, you will have
        <span>3 days</span> to pick it up before the reservation expires.
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="bookId" value="@Model.BookId" />
        <div class="actions">
            <button type="submit" class="btn btn-primary">✓ Confirm Reservation</button>
            <a asp-controller="Books" asp-action="Details" asp-route-id="@Model.BookId"
               class="btn btn-secondary">Go Back</a>
        </div>
    </form>

    <p class="rules-note">
        By confirming, you agree to pick up the book within 3 days of receiving
        your "Ready for Pickup" notification. Uncollected reservations are
        automatically cancelled and the copy is offered to the next person in queue.
    </p>
</div>