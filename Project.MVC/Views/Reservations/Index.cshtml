@model Project.Application.ViewModels.Reservation.UserReservationsViewModel
@{
    ViewData["Title"] = Model.IsAdminView ? "All Reservations" : "My Reservations";
    var displayList = Model.IsAdminView ? Model.AllReservations : Model.Reservations;
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    h2 {
        margin-bottom: 4px;
    }

    hr {
        border: none;
        border-top: 1px solid #ddd;
        margin-bottom: 20px;
    }

    .stats-row {
        display: flex;
        gap: 14px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .stat-card {
        background: #f9f9f9;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 14px 22px;
        text-align: center;
        min-width: 110px;
    }

    .stat-number {
        font-size: 26px;
        font-weight: 700;
        color: #1565c0;
    }

    .stat-label {
        font-size: 12px;
        color: #777;
        margin-top: 2px;
    }

    .alert {
        padding: 11px 16px;
        border-radius: 6px;
        margin-bottom: 12px;
        font-size: 14px;
    }

    .alert-success {
        background: #d4edda;
        border: 1px solid #c3e6cb;
        color: #155724;
    }

    .alert-error {
        background: #fdecea;
        border: 1px solid #f5c6cb;
        color: #721c24;
    }

    .alert-urgent {
        background: #fff3cd;
        border: 1px solid #ffc107;
        color: #856404;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .table-wrap {
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

    th {
        background: #f5f5f5;
        padding: 10px 14px;
        text-align: left;
        font-weight: 600;
        border-bottom: 2px solid #ddd;
    }

    td {
        padding: 10px 14px;
        border-bottom: 1px solid #eee;
        vertical-align: middle;
    }

    tr:hover td {
        background: #fafafa;
    }

    .badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 600;
        color: #fff;
        white-space: nowrap;
    }

    .badge-warning {
        background: #f0a500;
    }

    .badge-success {
        background: #4caf50;
    }

    .badge-secondary {
        background: #9e9e9e;
    }

    .badge-danger {
        background: #e25555;
    }

    .book-thumb {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .book-thumb img {
            width: 34px;
            height: 48px;
            object-fit: cover;
            border-radius: 3px;
            border: 1px solid #ddd;
        }

    .no-img {
        width: 34px;
        height: 48px;
        background: #eee;
        border-radius: 3px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 9px;
        color: #aaa;
    }

    .btn {
        padding: 5px 14px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        text-decoration: none;
        font-size: 13px;
        display: inline-block;
    }

    .btn-danger {
        background: #e25555;
        color: #fff;
    }

    .btn-secondary {
        background: #9e9e9e;
        color: #fff;
    }

    .btn-success {
        background: #4caf50;
        color: #fff;
    }

    .btn-sm {
        padding: 3px 10px;
        font-size: 12px;
    }

    .btn:hover {
        opacity: .88;
    }

    .empty-state {
        text-align: center;
        padding: 50px;
        color: #999;
    }

    .admin-banner {
        background: #e8eaf6;
        border: 1px solid #9fa8da;
        border-radius: 8px;
        padding: 10px 16px;
        margin-bottom: 16px;
        font-size: 13px;
        color: #283593;
    }
</style>

<div class="page-header">
    <div>
        <h2>
            @if (Model.IsAdminView)
            {
                <text>📋 All System Reservations</text>
            }
            else
            {
                <text>📚 My Reservations</text>
            }
        </h2>
        <p style="color:#777;font-size:13px;margin:0">
            @if (Model.IsAdminView)
            {
                <text>Manage all user reservations across the library system.</text>
            }
            else
            {
                <text>Track your place in the queue and pickup notifications.</text>
            }
        </p>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
        @if (Model.IsAdminView)
        {
            <form asp-action="ExpireSweep" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-secondary"
                        onclick="return confirm('Run expiry sweep on overdue reservations?')">
                    🔄 Expire Sweep
                </button>
            </form>
        }
        <a asp-controller="Books" asp-action="Index" class="btn btn-secondary">Browse Books</a>
    </div>
</div>
<hr />

@* ── Alerts ── *@
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">✅ @TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-error">⚠ @TempData["ErrorMessage"]</div>
}

@* ── Urgent alerts ── *@
@foreach (var urgent in Model.UrgentAlerts)
{
    <div class="alert alert-urgent">
        ⚠ <strong>Expiring Soon:</strong>
        @if (Model.IsAdminView)
        {
            <text><strong>@urgent.UserFullName's</strong> reservation for</text>
        }
        else
        {
            <text>Your reservation for</text>
        }
        <strong>@urgent.BookTitle</strong> expires <strong>@urgent.ExpiresAtDisplay</strong>.
    </div>
}

@* ── Stat cards ── *@
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-number">@Model.TotalCount</div>
        <div class="stat-label">Total</div>
    </div>
    <div class="stat-card">
        <div class="stat-number" style="color:#f0a500">@Model.PendingCount</div>
        <div class="stat-label">In Queue</div>
    </div>
    <div class="stat-card">
        <div class="stat-number" style="color:#4caf50">@Model.ReadyCount</div>
        <div class="stat-label">Ready</div>
    </div>
    <div class="stat-card">
        <div class="stat-number" style="color:#9e9e9e">@Model.FulfilledCount</div>
        <div class="stat-label">Fulfilled</div>
    </div>
    <div class="stat-card">
        <div class="stat-number" style="color:#e25555">@Model.CancelledCount</div>
        <div class="stat-label">Cancelled</div>
    </div>
</div>

@* ── Table ── *@
@if (!displayList.Any())
{
    <div class="empty-state">
        <div style="font-size:44px">📚</div>
        <p>@(Model.IsAdminView ? "No reservations found in the system." : "You have no reservations yet.")</p>
        <a asp-controller="Books" asp-action="Index" class="btn btn-secondary">Browse Books</a>
    </div>
}
else
{
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Book</th>
                    @if (Model.IsAdminView)
                    {
                        <th>Member</th>
                    }
                    <th>Reserved On</th>
                    <th>Expires / Pickup By</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var r in displayList)
                {
                    <tr>
                        <td>
                            <div class="book-thumb">
                                @if (!string.IsNullOrEmpty(r.BookCoverUrl))
                                {
                                    <img src="@r.BookCoverUrl" />
                                }
                                else
                                {
                                    <div class="no-img">N/A</div>
                                }
                                <div>
                                    <div style="font-weight:600">@r.BookTitle</div>
                                    <div style="font-size:12px;color:#888">@r.BookAuthor</div>
                                </div>
                            </div>
                        </td>

                        @if (Model.IsAdminView)
                        {
                            <td>
                                <div style="font-weight:600;font-size:13px">@r.UserFullName</div>
                                <div style="font-size:11px;color:#888">@r.UserEmail</div>
                            </td>
                        }

                        <td style="font-size:13px">@r.ReservedAtDisplay</td>

                        <td style="font-size:13px">
                            @r.ExpiresAtDisplay
                            @if (r.IsExpiringSoon)
                            {
                                <span style="color:#e25555;font-size:10px;display:block">⚠ Soon!</span>
                            }
                        </td>

                        <td>
                            <span class="badge @r.StatusBadgeClass">@r.StatusLabel</span>
                        </td>

                        <td>

                            @* ================= PICKUP BUTTON (ADDED ONLY) ================= *@
                            @if (Model.IsAdminView && r.StatusLabel.Contains("Ready"))
                            {
                                <form asp-controller="Reservations"
                                      asp-action="Pickup"
                                      method="post"
                                      style="display:inline"
                                      onsubmit="return confirm('Confirm pickup for @r.BookTitle ?')">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="reservationId" value="@r.Id" />

                                    <button type="submit" class="btn btn-success btn-sm">
                                        Pickup
                                    </button>
                                </form>
                            }

                            @* ================= CANCEL (UNCHANGED) ================= *@
                            @if (r.IsCancellable)
                            {
                                @if (Model.IsAdminView)
                                {
                                    <form asp-action="AdminCancel" method="post"
                                          style="display:inline"
                                          onsubmit="return confirm('Cancel @r.UserFullName\'s reservation for \'@r.BookTitle\'?')">

                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <input type="hidden" name="reservationUserId" value="@r.UserId" />

                                        <button type="submit" class="btn btn-danger btn-sm">Cancel</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Cancel"
                                          asp-route-id="@r.Id"
                                          method="post"
                                          style="display:inline"
                                          onsubmit="return confirm('Cancel your reservation for \'@r.BookTitle\'?')">

                                        @Html.AntiForgeryToken()

                                        <button type="submit" class="btn btn-danger btn-sm">Cancel</button>
                                    </form>
                                }
                            }
                            else
                            {
                                <span style="color:#ccc;font-size:12px">—</span>
                            }

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}