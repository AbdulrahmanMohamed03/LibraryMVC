@model Project.Application.ViewModels.SubscriptionPlan.UpdateSupscriptionPlanDTO

@{
    ViewData["Title"] = "Delete Subscription Plan";
}

<h2 class="mb-4">Delete Subscription Plan</h2>

<div class="row justify-content-center">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body text-center">
                <h5 class="card-title fw-bold text-danger">
                    @Model.Name
                </h5>
                <hr />
                <p class="card-text mb-1">
                    <strong>Fee:</strong> @Model.MonthlyFee.ToString("C")
                </p>
                <p class="card-text mb-1">
                    <strong>Limit:</strong> @Model.MonthlyBorrowLimit Books
                </p>
                <p class="card-text mb-0">
                    <strong>Duration:</strong> @Model.LoanDurationDays Days
                </p>
            </div>
            <div class="card-footer bg-light border-0 py-3 text-center">
                <p class="text-danger fw-bold mb-3">Are you sure you want to delete this plan?</p>
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger btn-sm rounded-pill px-3">Yes, Delete</button>
                    <a asp-action="Index" class="btn btn-secondary btn-sm rounded-pill px-3">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>