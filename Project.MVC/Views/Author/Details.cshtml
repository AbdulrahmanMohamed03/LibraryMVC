@model Project.Application.ViewModels.Author.AuthorWithBooksDto

@{
    ViewData["Title"] = "Author Details";
}

<div class="container mt-4">

    <!-- Author Info -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h2 class="card-title">@Model.FullName</h2>

            <p class="text-muted mb-1">
                <strong>Nationality:</strong> @Model.Nationality
            </p>

            <p class="text-muted mb-1">
                <strong>Bio:</strong> @Model.Bio
            </p>

            <p class="text-muted">
                <strong>Created At:</strong> @Model.CreatedAt.ToString("MMM dd, yyyy")
            </p>
        </div>
    </div>

    <!-- Books Section -->
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Books by @Model.FullName</h5>
        </div>

        <div class="card-body">

            @if (Model.Books != null && Model.Books.Any())
            {
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>ISBN</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var book in Model.Books)
                        {
                            <tr>
                                <td>@book.Title</td>
                                <td>@book.ISBN</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info">
                    This author has no books yet.
                </div>
            }

        </div>
    </div>

    <!-- Back Button -->
    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">
            Back to List
        </a>
    </div>

</div>