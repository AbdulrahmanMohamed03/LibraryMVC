@* Views/Authors/_CreateAuthorModal.cshtml *@
@model Project.Application.ViewModels.Author.CreateAuthorDto

<div class="modal-content">
    <div class="modal-header">
        <h3>Add New Author</h3>
        <button type="button" class="modal-close" onclick="closeAuthorModal()">✕</button>
    </div>
    <div class="modal-body">
        <form id="authorModalForm">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Full Name *</label>
                <input asp-for="FullName" class="form-control" id="modalAuthorName" />
                <span class="text-danger" id="modalNameError"></span>
            </div>

            <div class="form-group">
                <label>Nationality</label>
                <input asp-for="Nationality" class="form-control" id="modalAuthorNationality" />
            </div>

            <div class="form-group">
                <label>Bio</label>
                <textarea asp-for="Bio" class="form-control" rows="3"
                          id="modalAuthorBio"></textarea>
            </div>

            <div class="modal-actions">
                <button type="button" class="btn btn-primary"
                        onclick="submitAuthorModal()">
                    Save Author
                </button>
                <button type="button" class="btn btn-secondary"
                        onclick="closeAuthorModal()">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>