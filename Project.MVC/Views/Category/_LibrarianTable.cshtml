

@model Project.Application.ViewModels.Category.CategoryIndexViewModel
@{
    var isAdmin = User.IsInRole("Admin");
    // Standardize onto a single consistent model collection
    var filtered = Model.Categories?.ToList() ?? new List<Project.Application.ViewModels.Category.CategoryViewModel>();
}

<div class="card border-0 shadow-sm" style="background: var(--white); border: 1px solid var(--border);">
    <div class="table-responsive">
        @if (!filtered.Any())
        {
            <div style="padding:4rem; text-align:center; color:var(--ash)">
                <i class="fa-solid fa-magnifying-glass" style="font-size:2rem; color:var(--border); display:block; margin-bottom:1rem"></i>
                <h4 class="mt-3" style="font-family: 'Cormorant Garamond', serif; font-weight:700; color:var(--ink);">No Categories Found</h4>
                <p style="font-size:.85rem; color:var(--ash);">Try adjusting your search filters or add a new category entry.</p>
                <div style="margin-top:1.5rem;">
                    <a asp-action="Create" class="btn-gold" style="text-decoration:none; padding: .5rem 1.25rem; font-size:.75rem;">Add New Category</a>
                </div>
            </div>
        }
        else
        {
            <table class="table table-hover align-middle mb-0" style="width: 100%; border-collapse: collapse;">
                <thead style="background: var(--cream); border-bottom: 2px solid var(--gold);">
                    <tr>
                        <th class="ps-4" style="padding: .9rem 1.25rem; font-size: .63rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--ash); text-align:left;">Category Name</th>
                        <th class="text-center" style="padding: .9rem 1.25rem; font-size: .63rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--ash);">Books Count</th>
                        <th class="text-end pe-4" style="padding: .9rem 1.25rem; font-size: .63rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--ash); text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in filtered)
                    {
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td class="ps-4 fw-semibold" style="padding: 1.1rem 1.25rem; font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; color: var(--ink);">
                                @category.Name
                                @if (category.IsDeleted)
                                {
                                    <span class="ms-2" style="display: inline-block; padding: 2px 8px; background: var(--cream); border: 1px solid var(--border); font-size: .6rem; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--ash);">Archived</span>
                                }
                            </td>

                            <td class="text-center" style="padding: 1.1rem 1.25rem;">
                                <a asp-controller="Book"
                                   asp-action="Index"
                                   asp-route-categoryId="@category.Id"
                                   style="display: inline-block; padding: 2px 10px; background: var(--gold); color: var(--white); font-size: .65rem; font-weight: 700; letter-spacing: 1px; text-decoration: none; transition: background .2s;"
                                   onmouseover="this.style.background='var(--ink)'"
                                   onmouseout="this.style.background='var(--gold)'">
                                    @category.BookCount
                                </a>
                            </td>
                            <td class="text-end pe-4" style="padding: 1.1rem 1.25rem; text-align:right;">
                                <div class="d-flex justify-content-end gap-2" style="display:flex; justify-content:flex-end; gap: 0.75rem; align-items:center;">
                                    @if (category.IsDeleted)
                                    {
                                        <form asp-action="Restore" asp-route-id="@category.Id" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" style="font-size: .65rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #1a6832; background: transparent; border: none; border-bottom: 1px solid #1a6832; padding: 0 0 1px; cursor: pointer;">
                                                <i class="fa-solid fa-arrow-rotate-left me-1"></i> Restore
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <a asp-action="Edit" asp-route-id="@category.Id" style="font-size: .65rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--ink); padding-bottom: 1px; transition: all .2s;" onmouseover="this.style.color='var(--gold)'; this.style.borderColor='var(--gold)';" onmouseout="this.style.color='var(--ink)'; this.style.borderColor='var(--ink)';">Edit</a>

                                        @if (isAdmin)
                                        {
                                            <button type="button"
                                                    style="font-size: .65rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #b33; background: transparent; border: none; border-bottom: 1px solid #b33; padding: 0 0 1px; cursor: pointer; transition: opacity .2s;"
                                                    onmouseover="this.style.opacity='0.65'"
                                                    onmouseout="this.style.opacity='1'"
                                                    data-bs-toggle="modal" data-bs-target="#deleteModal"
                                                    data-category-id="@category.Id"
                                                    data-category-name="@category.Name"
                                                    data-book-count="@category.BookCount">
                                                Delete
                                            </button>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (isAdmin)
{
    <partial name="_DeleteModal" />
}