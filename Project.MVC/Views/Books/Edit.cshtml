@model Project.Application.ViewModels.Book.BookFormViewModel

@{
    ViewData["Title"] = Model.FormTitle;
}

@section Styles {
    <link rel="stylesheet" href="~/css/vendor.css" />
    <link rel="stylesheet" href="~/icomoon/style.css" />
    <link rel="stylesheet" href="~/css/style.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/css/select2.min.css" rel="stylesheet" />
    
    <style>
        .booksaw-form-card { background: #fff; padding: 40px; border: 1px solid #e1e1e1; }
        .form-control, .form-select { border-radius: 0 !important; border: 1px solid #ccc !important; padding: 12px !important; font-family: sans-serif; font-size: 0.95rem; }
        .form-control:focus, .form-select:focus { border-color: #c5a880 !important; box-shadow: none !important; }
        .control-label { font-weight: bold; text-transform: uppercase; font-size: 0.8rem; color: #444; letter-spacing: 1px; margin-bottom: 6px; display: block; }
        
        /* Buttons matching the template style guide */
        .btn-booksaw-submit { background: #111; color: #fff; border: 1px solid #111; border-radius: 0; padding: 12px 30px; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px; transition: all 0.3s ease; display: inline-block; text-decoration: none; text-align: center; border-none: none; }
        .btn-booksaw-submit:hover { background: #c5a880; border-color: #c5a880; color: #fff; }
        .btn-booksaw-inline { background: #c5a880; color: #fff; border: 1px solid #c5a880; border-radius: 0; padding: 0 20px; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px; transition: all 0.3s ease; height: 45px; display: flex; align-items: center; white-space: nowrap; text-decoration: none; }
        .btn-booksaw-inline:hover { background: #111; border-color: #111; color: #fff; }
        
        .current-cover { max-height: 140px; border: 1px solid #e1e1e1; padding: 5px; background: #fff; display: block; margin-bottom: 10px; }
        .img-preview { max-height: 180px; margin-top: 15px; border: 1px solid #e1e1e1; padding: 5px; background: #fff; display: none; }
        
        /* BookSaw Custom Flat Overlay Modal UI */
        .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(17,17,17,0.6); z-index: 1050; align-items: center; justify-content: center; backdrop-filter: blur(2px); }
        .modal-overlay.active { display: flex; }
        .modal-box { background: #fff; border: 1px solid #111; width: 500px; max-width: 95vw; padding: 35px; box-shadow: 0 10px 30px rgba(0,0,0,0.15); }
        .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; border-bottom: 1px solid #e1e1e1; padding-bottom: 10px; }
        .modal-header h3 { margin: 0; font-family: 'Cormorant Garamond', serif; font-weight: 700; text-transform: uppercase; font-size: 1.5rem; }
        .modal-close { background: none; border: none; font-size: 24px; cursor: pointer; color: #111; transition: color 0.2s ease; }
        .modal-close:hover { color: #c5a880; }
        .modal-actions { display: flex; gap: 15px; margin-top: 25px; border-top: 1px solid #e1e1e1; pt-3; }

        /* Select2 Flat Border Styling Integration override */
        .select2-container { flex: 1; min-width: 0; }
        .select2-container .select2-selection--single { height: 45px !important; border: 1px solid #ccc !important; border-radius: 0 !important; }
        .select2-container .select2-selection--single .select2-selection__rendered { line-height: 43px !important; padding-left: 12px !important; color: #111; }
        .select2-container .select2-selection--single .select2-selection__arrow { height: 43px !important; }
        .select2-container .select2-selection--single .select2-selection__clear { margin-top: 11px; }
        .select2-dropdown { border: 1px solid #111 !important; border-radius: 0 !important; }
    </style>
}

<div class="py-5" style="background-color: #f3f2ec; min-height: 85vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="booksaw-form-card shadow-sm">
                    <h2 class="mb-4 text-uppercase fw-bold" style="font-family: 'Cormorant Garamond', serif; border-bottom: 2px solid #111; padding-bottom: 10px;">@Model.FormTitle</h2>
                    
                    <form asp-action="Edit" method="post" enctype="multipart/form-data" id="bookForm">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CoverImageUrl" />

                        <div class="mb-3">
                            <label asp-for="Title" class="control-label"></label>
                            <input asp-for="Title" class="form-control" placeholder="Book Title" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ISBN" class="control-label"></label>
                            <input asp-for="ISBN" class="form-control" placeholder="13-digit sequence" />
                            <span asp-validation-for="ISBN" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="control-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Provide summary overview annotations..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <!-- AUTHOR FIELD SETUP -->
                        <div class="mb-3">
                            <label asp-for="AuthorId" class="control-label"></label>
                            <div class="d-flex gap-2 align-items-center">
                                <select name="AuthorId" id="authorSelect">
                                    <option value="">-- Search Author --</option>
                                    @foreach (var author in Model.Authors)
                                    {
                                        if (author.Value == Model.AuthorId.ToString())
                                        {
                                            <option value="@author.Value" selected="selected">@author.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@author.Value">@author.Text</option>
                                        }
                                    }
                                </select>

                                <button type="button" class="btn-booksaw-inline" onclick="openAuthorModal()">
                                    <i class="fa-solid fa-plus me-1"></i> New Author
                                </button>
                            </div>
                            <span asp-validation-for="AuthorId" class="text-danger small d-block mt-1"></span>
                        </div>

                        <!-- CATEGORY FIELD SETUP -->
                        <div class="mb-3">
                            <label asp-for="CategoryId" class="control-label"></label>
                            <div class="d-flex gap-2 align-items-center">
                                <select name="CategoryId" id="categorySelect">
                                    <option value="">-- Search Category --</option>
                                    @foreach (var category in Model.Categories)
                                    {
                                        if (category.Value == Model.CategoryId.ToString())
                                        {
                                            <option value="@category.Value" selected="selected">@category.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@category.Value">@category.Text</option>
                                        }
                                    }
                                </select>

                                <button type="button" class="btn-booksaw-inline" onclick="openCategoryModal()">
                                    <i class="fa-solid fa-plus me-1"></i> New Category
                                </button>
                            </div>
                            <span asp-validation-for="CategoryId" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PublishedYear" class="control-label"></label>
                                <input asp-for="PublishedYear" class="form-control" type="number" placeholder="YYYY" />
                                <span asp-validation-for="PublishedYear" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="TotalCopies" class="control-label"></label>
                                <input asp-for="TotalCopies" class="form-control" type="number" placeholder="0" />
                                <span asp-validation-for="TotalCopies" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="BorrowFee" class="control-label"></label>
                                <input asp-for="BorrowFee" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                <span asp-validation-for="BorrowFee" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DailyFineRate" class="control-label"></label>
                                <input asp-for="DailyFineRate" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                <span asp-validation-for="DailyFineRate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CoverImage" class="control-label"></label>
                            
                            @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                            {
                                <div id="currentCoverWrapper">
                                    <img src="@Model.CoverImageUrl" alt="Current Cover Asset" class="current-cover img-fluid" />
                                    <span class="text-muted small d-block mb-2">Current file saved — upload a new image sequence to overwrite.</span>
                                </div>
                            }

                            <input asp-for="CoverImage" class="form-control" type="file" accept="image/*" onchange="previewImage(this)" />
                            <span asp-validation-for="CoverImage" class="text-danger small"></span>
                            <img id="imgPreview" class="img-preview img-fluid" alt="Preview Layout Image Asset" />
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                            <a asp-action="Index" class="text-decoration-none text-muted small text-uppercase fw-bold">
                                <i class="fa-solid fa-arrow-left-long me-2"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-booksaw-submit">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Author Modal Overlay -->
<div id="authorModalOverlay" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Add New Author</h3>
            <button type="button" class="modal-close" onclick="closeAuthorModal()">✕</button>
        </div>

        <div class="mb-3">
            <label class="control-label">Full Name *</label>
            <input type="text" id="modalAuthorName" class="form-control" placeholder="e.g. Ernest Hemingway" />
            <span class="text-danger small" id="modalNameError"></span>
        </div>

        <div class="mb-3">
            <label class="control-label">Nationality</label>
            <input type="text" id="modalAuthorNationality" class="form-control" placeholder="e.g. American" />
        </div>

        <div class="mb-3">
            <label class="control-label">Bio Summary</label>
            <textarea id="modalAuthorBio" class="form-control" rows="3" placeholder="Brief chronicle notes..."></textarea>
        </div>

        <div class="modal-actions">
            <button type="button" class="btn btn-booksaw-submit w-50" onclick="submitAuthorModal()">Save Author</button>
            <button type="button" class="btn btn-booksaw-inline w-50 justify-content-center" onclick="closeAuthorModal()">Cancel</button>
        </div>
    </div>
</div>

<!-- Category Modal Overlay -->
<div id="categoryModalOverlay" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Add New Category</h3>
            <button type="button" class="modal-close" onclick="closeCategoryModal()">✕</button>
        </div>

        <div class="mb-3">
            <label class="control-label">Category Name *</label>
            <input type="text" id="modalCategoryName" class="form-control" placeholder="e.g. Science Fiction" />
            <span class="text-danger small" id="modalCategoryError"></span>
        </div>

        <div class="modal-actions">
            <button type="button" class="btn btn-booksaw-submit w-50" onclick="submitCategoryModal()">Save Category</button>
            <button type="button" class="btn btn-booksaw-inline w-50 justify-content-center" onclick="closeCategoryModal()">Cancel</button>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/js/select2.min.js"></script>

    <script>
        const FORM_KEY = 'bookFormData_edit';

        $(document).ready(function () {
            $('#authorSelect').select2({
                placeholder: '-- Search Author --',
                allowClear: true
            });

            $('#categorySelect').select2({
                placeholder: '-- Search Category --',
                allowClear: true
            });

            restoreFormData();
        });

        function previewImage(input) {
            const preview = document.getElementById('imgPreview');
            const currentCover = document.getElementById('currentCoverWrapper');
            
            if (input.files && input.files[0]) {
                preview.src = URL.createObjectURL(input.files[0]);
                preview.style.display = 'block';
                if(currentCover) currentCover.style.opacity = '0.4'; 
            } else {
                preview.style.display = 'none';
                if(currentCover) currentCover.style.opacity = '1';
            }
        }

        /* =========================================================================
           AUTHOR MODAL LOGIC
           ========================================================================= */
        function openAuthorModal() {
            saveFormData();
            document.getElementById('modalAuthorName').value = '';
            document.getElementById('modalAuthorNationality').value = '';
            document.getElementById('modalAuthorBio').value = '';
            document.getElementById('modalNameError').textContent = '';
            document.getElementById('authorModalOverlay').classList.add('active');
        }

        function closeAuthorModal() {
            document.getElementById('authorModalOverlay').classList.remove('active');
        }

        document.getElementById('authorModalOverlay').addEventListener('click', function (e) {
            if (e.target === this) closeAuthorModal();
        });

        function submitAuthorModal() {
            const name = document.getElementById('modalAuthorName').value.trim();
            const nationality = document.getElementById('modalAuthorNationality').value.trim();
            const bio = document.getElementById('modalAuthorBio').value.trim();
            const token = document.querySelector('[name="__RequestVerificationToken"]').value;

            if (!name) {
                document.getElementById('modalNameError').textContent = 'Full name field verification required.';
                return;
            }
            document.getElementById('modalNameError').textContent = '';

            fetch('/Author/CreateModal', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `FullName=${encodeURIComponent(name)}&Nationality=${encodeURIComponent(nationality)}&Bio=${encodeURIComponent(bio)}`
            })
            .then(r => {
                if (!r.ok) throw new Error('Network channel response failure.');
                return r.json();
            })
            .then(author => {
                const option = new Option(author.text, author.id, true, true);
                $('#authorSelect').append(option).trigger('change');
                closeAuthorModal();
            })
            .catch(() => {
                document.getElementById('modalNameError').textContent = 'An operational error has occurred. Verify entry structures.';
            });
        }

        /* =========================================================================
           CATEGORY MODAL LOGIC
           ========================================================================= */
        function openCategoryModal() {
            saveFormData();
            document.getElementById('modalCategoryName').value = '';
            document.getElementById('modalCategoryError').textContent = '';
            document.getElementById('categoryModalOverlay').classList.add('active');
        }

        function closeCategoryModal() {
            document.getElementById('categoryModalOverlay').classList.remove('active');
        }

        document.getElementById('categoryModalOverlay').addEventListener('click', function (e) {
            if (e.target === this) closeCategoryModal();
        });

        function submitCategoryModal() {
            const name = document.getElementById('modalCategoryName').value.trim();
            const token = document.querySelector('[name="__RequestVerificationToken"]').value;

            if (!name) {
                document.getElementById('modalCategoryError').textContent = 'Category name is required.';
                return;
            }
            document.getElementById('modalCategoryError').textContent = '';

            fetch('/Category/CreateModal', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `name=${encodeURIComponent(name)}` 
            })
            .then(r => {
                if (!r.ok) throw new Error('Server error');
                return r.json();
            })
            .then(category => {
                const option = new Option(category.text, category.id, true, true);
                $('#categorySelect').append(option).trigger('change');
                closeCategoryModal();
            })
            .catch(() => {
                document.getElementById('modalCategoryError').textContent = 'Name already exists.';
            });
        }

        /* =========================================================================
           FORM PERSISTENCE EXTENSION
           ========================================================================= */
        function saveFormData() {
            const form = document.getElementById('bookForm');
            const data = {};

            new FormData(form).forEach((val, key) => {
                if (key !== '__RequestVerificationToken' && key !== 'CoverImage')
                    data[key] = val;
            });

            const selectedAuthor = $('#authorSelect').find(':selected');
            if (selectedAuthor.val()) {
                data['_authorText'] = selectedAuthor.text();
            }

            const selectedCategory = $('#categorySelect').find(':selected');
            if (selectedCategory.val()) {
                data['_categoryText'] = selectedCategory.text();
            }

            sessionStorage.setItem(FORM_KEY, JSON.stringify(data));
        }

        function restoreFormData() {
            const saved = sessionStorage.getItem(FORM_KEY);
            if (!saved) return;

            const data = JSON.parse(saved);

            Object.entries(data).forEach(([key, val]) => {
                if (key.startsWith('_')) return;
                const el = document.querySelector(`[name="${key}"]`);
                if (el && el.tagName !== 'SELECT' && el.type !== 'file')
                    el.value = val;
            });

            if (data['AuthorId']) {
                if (!$('#authorSelect').find(`option[value="${data['AuthorId']}"]`).length && data['_authorText']) {
                    const option = new Option(data['_authorText'], data['AuthorId'], true, true);
                    $('#authorSelect').append(option);
                }
                $('#authorSelect').val(data['AuthorId']).trigger('change');
            }

            if (data['CategoryId']) {
                if (!$('#categorySelect').find(`option[value="${data['CategoryId']}"]`).length && data['_categoryText']) {
                    const option = new Option(data['_categoryText'], data['CategoryId'], true, true);
                    $('#categorySelect').append(option);
                }
                $('#categorySelect').val(data['CategoryId']).trigger('change');
            }

            sessionStorage.removeItem(FORM_KEY);
        }
    </script>
}