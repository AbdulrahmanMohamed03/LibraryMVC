@model Project.Application.ViewModels.Book.BookIndexViewModel

@{
    ViewData["Title"] = "Our Books Collection";
}

@section Styles {
    <link rel="stylesheet" href="~/css/vendor.css" />
    <link rel="stylesheet" href="~/icomoon/style.css" />
    <link rel="stylesheet" href="~/css/style.css" />
}

<section id="popular-books" class="bookshelf py-5" style="background-color: #f3f2ec;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-5">
            <div class="section-header">
                <span class="text-muted text-uppercase tracking-widest small">Our Catalog</span>
                <h2 class="section-title text-uppercase m-0" style="font-family: 'Cormorant Garamond', serif; font-weight: 700;">Books Collection</h2>
            </div>
            @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
            {
                <a asp-action="Create" class="btn btn-outline-dark rounded-0 px-4 text-uppercase fw-bold">+ Add New Book</a>
            }
        </div>

        <div class="row">
            @if (Model.Books != null && Model.Books.Any())
            {
                @foreach (var book in Model.Books)
                {
                    <div class="col-md-3 col-sm-6 mb-4">
                        <div class="product-item bg-white p-3 border text-center h-100 d-flex flex-column justify-content-between" style="transition: all 0.3s ease;">
                            <div class="image-holder mb-3" style="height: 300px; overflow: hidden; background: #faf9f5;">
                                @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                                {
                                    <img src="@book.CoverImageUrl" alt="@book.Title" class="img-fluid h-100 w-100" style="object-fit: contain;" />
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center h-100 text-muted bg-light border">
                                        <span>No Cover</span>
                                    </div>
                                }
                            </div>
                            
                            <div class="product-detail">
                                <h3 class="product-title h6 text-uppercase fw-bold m-0" style="letter-spacing: 0.5px;">
                                    <a asp-action="Details" asp-route-id="@book.Id" class="text-decoration-none text-dark">@book.Title</a>
                                </h3>
                                <span class="item-author text-muted small font-italic d-block mb-2">By @book.AuthorName</span>

                                <div class="mb-3">
                                    @if (book.AvailableCopies > 0)
                                    {
                                        <span class="badge bg-success rounded-0 text-uppercase small">@book.AvailableCopies Available</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger rounded-0 text-uppercase small">Out of Stock</span>
                                    }
                                </div>

                                <div class="d-grid gap-2">
                                    <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-dark rounded-0 text-uppercase tracking-wider btn-sm">View Details</a>
                                    
                                    @if (book.AvailableCopies == 0)
                                    {
                                        <button type="button" class="btn btn-accent rounded-0 text-uppercase btn-sm" style="background-color: #c5a880; color: white;" onclick="alert('Reservation request submitted!')">Reserve Book</button>
                                    }
                                </div>
                            </div>

                            @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
                            {
                                <div class="admin-controls mt-3 pt-2 border-top bg-light d-flex justify-content-around small">
                                    <a asp-action="Edit" asp-route-id="@book.Id" class="text-dark text-decoration-none"><i class="icon icon-edit"></i> Edit</a>
                                    <span class="text-muted">|</span>
                                    <a asp-action="Delete" asp-route-id="@book.Id" class="text-danger text-decoration-none"><i class="icon icon-trash"></i> Delete</a>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted fs-5">No literary works found in the database.</p>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/modernizr.js"></script>
    <script src="~/js/plugins.js"></script>
    <script src="~/js/script.js"></script>
}