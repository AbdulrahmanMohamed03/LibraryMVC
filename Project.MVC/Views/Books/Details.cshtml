
@model Project.Application.ViewModels.Book.BookViewModel
@{
    ViewData["Title"] = "Book Details - " + Model.Title;
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var isLibrarianOrAdmin = User.IsInRole("Admin") || User.IsInRole("Librarian");
}

<style>
    h2 {
        margin-bottom: 16px;
    }

    hr {
        border: none;
        border-top: 1px solid #ddd;
        margin-bottom: 24px;
    }

    .details-layout {
        display: flex;
        gap: 40px;
        align-items: flex-start;
    }

    .cover-box img {
        width: 160px;
        border: 1px solid #ddd;
        border-radius: 6px;
    }

    .no-cover-box {
        width: 160px;
        height: 220px;
        background: #f0f0f0;
        border: 1px solid #ddd;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #999;
        font-size: 13px;
    }

    dl {
        font-size: 14px;
        flex: 1;
    }

    dt {
        font-weight: 600;
        color: #333;
        margin-top: 12px;
    }

    dd {
        color: #555;
        margin: 2px 0 0 0;
    }

    .badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 12px;
        font-size: 12px;
        color: #fff;
    }

    .badge-success {
        background: #4caf50;
    }

    .badge-danger {
        background: #e25555;
    }

    .action-box {
        margin-top: 22px;
        padding: 18px 20px;
        border-radius: 8px;
        max-width: 440px;
    }

    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 28px;
    }

    .btn {
        padding: 8px 20px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        text-decoration: none;
        font-size: 14px;
        display: inline-block;
    }

    .btn-primary {
        background: #1565c0;
        color: #fff;
    }

    .btn-warning {
        background: #f0a500;
        color: #fff;
    }

    .btn-secondary {
        background: #9e9e9e;
        color: #fff;
    }

    .btn:hover {
        opacity: .88;
    }
</style>

<h2>Book Details</h2>
<hr />

@* ── Toast messages ── *@
@if (TempData["ErrorMessage"] != null)
{
    <div style="background:#ffebee;border:1px solid #ef9a9a;color:#c62828;
        padding:12px;border-radius:6px;margin-bottom:18px">
        @TempData["ErrorMessage"]
    </div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div style="background:#e8f5e9;border:1px solid #81c784;color:#2e7d32;
        padding:12px;border-radius:6px;margin-bottom:18px">
        @TempData["SuccessMessage"]
    </div>
}

<div class="details-layout">

    <div class="cover-box">
        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
        {
            <img src="@Model.CoverImageUrl" alt="@Model.Title cover" />
        }
        else
        {
            <div class="no-cover-box">No Image</div>
        }
    </div>

    <div style="flex:1">
        <dl>
            <dt>Title</dt>
            <dd>@Model.Title</dd>
            <dt>Author</dt>
            <dd>@Model.AuthorName</dd>
            <dt>Category</dt>
            <dd>@Model.CategoryName</dd>
            <dt>Description</dt>
            <dd>@(Model.Description ?? "—")</dd>
            <dt>Published Year</dt>
            <dd>@(Model.PublishedYear?.ToString() ?? "—")</dd>
            <dt>Borrow Fee / Daily Fine</dt>
            <dd>@Model.BorrowFee.ToString("C") / @Model.DailyFineRate.ToString("C")</dd>
            <dt>Availability</dt>
            <dd>
                @if (Model.IsAvailable)
                {
                    <span class="badge badge-success">@Model.AvailableCopies of @Model.TotalCopies Available</span>
                }
                else
                {
                    <span class="badge badge-danger">All @Model.TotalCopies Copies Checked Out</span>
                }
            </dd>
        </dl>


 
        @if (isLibrarianOrAdmin)
        {
            <div class="action-box" style="background:#fce4ec;border:1px solid #f48fb1;color:#880e4f;font-size:13px">
                @if (Model.IsAvailable)
                {
                    <text>📚 <strong>Librarian Note:</strong> @Model.AvailableCopies copy(ies) available for checkout via the Borrowing desk.</text>
                }
                else
                {
                    <text>📭 <strong>Librarian Note:</strong> All copies are checked out. The queue engine will notify the next reserved user automatically on return.</text>
                }
            </div>
        }
        else if (!isAuthenticated)
        {
            <div class="action-box" style="background:#f5f5f5;border:1px solid #ddd;font-size:14px;color:#555">
                📚 <a asp-controller="Account" asp-action="Login" style="color:#1565c0;font-weight:600">Sign in</a>
                to @(Model.IsAvailable ? "request borrowing" : "join the reservation queue for") this book.
            </div>
        }
        else if (Model.IsCurrentlyBorrowing)
        {
          
            <div class="action-box" style="background:#e3f2fd;border:1px solid #90caf9;">
                <div style="font-size:15px;font-weight:600;color:#0d47a1;margin-bottom:6px">
                    📖 You Currently Have This Book
                </div>
                <div style="font-size:13px;color:#37474f;margin-bottom:14px">
                    You have already checked out a copy of this book. You cannot place another borrowing request or join the reservation queue until it is returned.
                </div>
                <a asp-controller="BorrowingRecords" asp-action="Index" class="btn btn-primary" style="font-size:13px">
                    📋 View My Borrowing Records
                </a>
            </div>
        }
        else if (Model.HasActiveReservation)
        {
            @* ── Smart block: user has an active Pending/Ready reservation ──── *@
            <div class="action-box" style="background:#e8f5e9;border:1px solid #81c784;">
                <div style="font-size:15px;font-weight:600;color:#2e7d32;margin-bottom:6px">
                    ✅ You Already Have a Reservation for This Book
                </div>
                <div style="font-size:13px;color:#388e3c;margin-bottom:14px">
                    You have already reserved this book. Please proceed to the pickup
                    window when it's your turn, or manage your reservation below.
                </div>
                <a asp-controller="Reservations" asp-action="Index"
                   class="btn btn-primary" style="font-size:13px">
                    📋 View My Reservations
                </a>
            </div>
        }
        else if (Model.IsAvailable)
        {
          
            <div class="action-box" style="background:#e3f2fd;border:1px solid #90caf9;">
                <div style="font-size:15px;font-weight:600;color:#0d47a1;margin-bottom:6px">
                    📚 Borrow This Book
                </div>
                <div style="font-size:13px;color:#455a64;margin-bottom:14px">
                    Submit a borrowing request. A librarian will process it shortly.
                </div>
                <form asp-controller="BorrowingRecords" asp-action="BorrowBook" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="bookId" value="@Model.Id" />
                    <button type="submit" class="btn btn-primary">📩 Request Borrow</button>
                </form>
            </div>
        }
        else
        {
            
            <div class="action-box" style="background:#fff8e1;border:1px solid #ffd54f;">
                <div style="font-size:15px;font-weight:600;color:#e65100;margin-bottom:6px">
                    📭 Join the Waiting Queue
                </div>
                <div style="font-size:13px;color:#5d4037;margin-bottom:14px">
                    All copies are checked out. Reserve your place — you'll be
                    notified when a copy becomes available for you.
                </div>
                <a asp-controller="Reservations" asp-action="Confirm" asp-route-id="@Model.Id"
                   class="btn btn-primary">
                    📋 Reserve This Book
                </a>
            </div>
        }
    </div>
</div>
                    </a>
                <div class="pt-3 border-top d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="text-decoration-none text-muted tracking-wide small text-uppercase fw-bold">
                        <i class="fa-solid fa-arrow-left me-2"></i> Catalog Grid
                    </a>
                    
                    @if (isLibrarianOrAdmin)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-booksaw">
                            <i class="fa-solid fa-pen-to-square me-2"></i> Edit Record
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/plugins.js"></script>
    <script src="~/js/script.js"></script>
}
<div class="form-actions">
    @if (isLibrarianOrAdmin)
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>            {
                <div class="reservation-box"
                     style="background:#fce4ec; border:1px solid #f48fb1; color:#880e4f; font-size:13px;">

                    📭
                    <strong>Librarian Note:</strong>

                    All copies are currently out.
                    The system will automatically notify
                    the next person in the queue upon return.
                </div>
            }
        }

    </div>
</div>

                <div class="pt-3 border-top d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="text-decoration-none text-muted tracking-wide small text-uppercase fw-bold">
                        <i class="fa-solid fa-arrow-left me-2"></i> Catalog Grid
                    </a>
                    
                    @if (isLibrarianOrAdmin)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-booksaw">
                            <i class="fa-solid fa-pen-to-square me-2"></i> Edit Record
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/plugins.js"></script>
    <script src="~/js/script.js"></script>
}