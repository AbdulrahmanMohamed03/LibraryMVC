@model Project.Application.ViewModels.Book.BookViewModel

@{
    ViewData["Title"] = "Book Details - " + Model.Title;

    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var isLibrarianOrAdmin =
        User.IsInRole("Admin") ||
        User.IsInRole("Librarian");
}

@section Styles {
    <link rel="stylesheet" href="~/css/vendor.css" />
    <link rel="stylesheet" href="~/icomoon/style.css" />
    <link rel="stylesheet" href="~/css/style.css" />

    <style>
        .meta-label {
            font-weight: bold;
            text-transform: uppercase;
            font-size: 0.8rem;
            color: #747474;
            letter-spacing: 1px;
        }

        .meta-value {
            font-size: 1.05rem;
            color: #111;
            margin-bottom: 15px;
        }

        .booksaw-alert {
            border-radius: 0;
            border-width: 1px 1px 1px 4px;
            font-family: sans-serif;
            font-size: 0.95rem;
        }

        .reservation-card {
            background: #fff;
            border: 1px solid #e1e1e1;
            padding: 25px;
            margin-top: 25px;
        }

        .btn-booksaw {
            background: #111;
            color: #fff;
            border: 1px solid #111;
            border-radius: 0;
            padding: 12px 25px;
            text-transform: uppercase;
            font-size: 0.9rem;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

            .btn-booksaw:hover {
                background: #c5a880;
                border-color: #c5a880;
                color: #fff;
            }

        .btn-reserve-accent {
            background: #c5a880;
            color: #fff;
            border: 1px solid #c5a880;
            border-radius: 0;
            padding: 12px 25px;
            text-transform: uppercase;
            font-size: 0.9rem;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

            .btn-reserve-accent:hover {
                background: #111;
                border-color: #111;
                color: #fff;
            }
    </style>
}

<div class="py-5" style="background-color: #f3f2ec; min-height: 85vh;">

    <div class="container bg-white p-5 border shadow-sm">

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger booksaw-alert border-start border-danger mb-4 text-danger bg-light">
                <i class="fa-solid fa-circle-exclamation me-2"></i>
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success booksaw-alert border-start border-success mb-4 text-success bg-light">
                <i class="fa-solid fa-circle-check me-2"></i>
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="row">

            <div class="col-md-4 text-center mb-4 mb-md-0">

                @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                {
                    <img src="@Model.CoverImageUrl"
                         alt="@Model.Title cover"
                         class="img-fluid border p-2 shadow-sm"
                         style="max-height: 450px; background: #fff;" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center border text-muted bg-light mx-auto"
                         style="height: 380px; max-width: 280px;">

                        <span class="text-uppercase tracking-wider small">
                            No Cover Graphic Available
                        </span>
                    </div>
                }

            </div>

            <div class="col-md-8 ps-md-5 d-flex flex-column justify-content-between">

                <div>

                    <span class="text-uppercase tracking-widest text-muted small mb-1 d-block">
                        @Model.CategoryName
                    </span>

                    <h1 class="display-6 fw-bold text-dark m-0"
                        style="font-family: 'Cormorant Garamond', serif;">

                        @Model.Title
                    </h1>

                    <p class="lead font-italic mt-1 mb-4"
                       style="color: #c5a880 !important; font-size: 1.15rem;">

                        By @Model.AuthorName
                    </p>

                    <div class="row border-top border-bottom py-4 my-4 bg-light px-3">

                        <div class="col-sm-6">

                            <div class="meta-label">
                                International ISBN
                            </div>

                            <div class="meta-value">
                                @(string.IsNullOrEmpty(Model.ISBN)
                                    ? "Not Available"
                                    : Model.ISBN)
                            </div>

                            <div class="meta-label">
                                Published Year
                            </div>

                            <div class="meta-value">
                                @(Model.PublishedYear?.ToString() ?? "—")
                            </div>

                            <div class="meta-label">
                                Borrow Fee / Fine Rate
                            </div>

                            <div class="meta-value">
                                @Model.BorrowFee.ToString("C")
                                /
                                @Model.DailyFineRate.ToString("C")
                            </div>

                        </div>

                        <div class="col-sm-6">

                            <div class="meta-label">
                                Stock Metrics
                            </div>

                            <div class="meta-value">
                                @Model.TotalCopies Total Physical Units
                            </div>

                            <div class="meta-label">
                                Created At
                            </div>

                            <div class="meta-value">
                                @Model.CreatedAtDisplay
                            </div>

                            <div class="meta-label">
                                Availability Status
                            </div>

                            <div class="meta-value">

                                @if (Model.IsAvailable)
                                {
                                    <span class="text-success fw-bold">
                                        <i class="fa-solid fa-square-check me-1"></i>
                                        @Model.AvailableCopies Copies Left
                                    </span>
                                }
                                else
                                {
                                    <span class="text-danger fw-bold">
                                        <i class="fa-solid fa-triangle-exclamation me-1"></i>
                                        All Copies Checked Out
                                    </span>
                                }

                            </div>

                        </div>

                    </div>

                    <div class="book-synopsis my-4">

                        <h6 class="text-uppercase tracking-wider fw-bold text-dark mb-2"
                            style="font-size: 0.85rem;">

                            Synopsis
                        </h6>

                        <p class="text-secondary"
                           style="line-height: 1.7; font-size: 1rem;">

                            @(string.IsNullOrEmpty(Model.Description)
                                ? "No summary overview is currently available for this volume entry."
                                : Model.Description)
                        </p>

                    </div>

                </div>

                <div class="mt-2 mb-4">

                    @if (isLibrarianOrAdmin)
                    {
                        <div class="reservation-card border-start border-danger"
                             style="background:#fffbfb;">

                            @if (Model.IsAvailable)
                            {
                                <p class="m-0 text-danger small">
                                    <strong>
                                        <i class="fa-solid fa-circle-info me-1"></i>
                                        Librarian Note:
                                    </strong>

                                    @Model.AvailableCopies copy(ies)
                                    available for checkout processing.
                                </p>
                            }
                            else
                            {
                                <p class="m-0 text-danger small">
                                    <strong>
                                        <i class="fa-solid fa-circle-info me-1"></i>
                                        Inventory Notice:
                                    </strong>

                                    Zero operational copies available.
                                    The system automatically notifies
                                    queued users when a book is returned.
                                </p>
                            }

                        </div>
                    }
                    else if (!isAuthenticated)
                    {
                        <div class="reservation-card bg-light">

                            <p class="m-0 text-secondary small">

                                @(Model.IsAvailable ? "📚" : "📭")

                                <a asp-controller="Account"
                                   asp-action="Login"
                                   class="fw-bold text-dark text-decoration-underline">

                                    Sign in
                                </a>

                                to
                                @(Model.IsAvailable
                                    ? "request borrowing this book."
                                    : "join the reservation waiting queue.")
                            </p>

                        </div>
                    }
                    else if (Model.IsCurrentlyBorrowing)
                    {
                        <div class="reservation-card border-start border-primary"
                             style="background:#f4f9ff;">

                            <h5 class="fw-bold text-primary mb-1"
                                style="font-size:1.1rem;">

                                📖 You Currently Borrowed This Book
                            </h5>

                            <p class="text-muted small mb-3">
                                You already have an active borrowing record
                                for this book. Return it first before placing
                                another request or reservation.
                            </p>

                            <a asp-controller="BorrowingRecords"
                               asp-action="Index"
                               class="btn-booksaw btn-sm">

                                📋 View Borrowing Records
                            </a>

                        </div>
                    }
                    else if (Model.HasActiveReservation)
                    {
                        <div class="reservation-card border-start border-success"
                             style="background:#f6fff8;">

                            <h5 class="fw-bold text-success mb-1"
                                style="font-size:1.1rem;">

                                ✅ Active Reservation Found
                            </h5>

                            <p class="text-muted small mb-3">
                                You already reserved this title.
                                Please monitor your reservation queue
                                or wait for pickup notification.
                            </p>

                            <a asp-controller="Reservations"
                               asp-action="Index"
                               class="btn-booksaw btn-sm">

                                📋 View Reservations
                            </a>

                        </div>
                    }
                    else if (Model.IsAvailable)
                    {
                        <div class="reservation-card border-start border-primary"
                             style="background:#f4f9ff;">

                            <h5 class="fw-bold text-primary mb-1"
                                style="font-size:1.1rem;">

                                📚 Request to Borrow
                            </h5>

                            <p class="text-muted small mb-3">
                                Submit a borrowing request.
                                A librarian will review and approve it shortly.
                            </p>

                            <form asp-controller="BorrowingRecords"
                                  asp-action="BorrowBook"
                                  method="post">

                                @Html.AntiForgeryToken()

                                <input type="hidden"
                                       name="bookId"
                                       value="@Model.Id" />

                                <button type="submit"
                                        class="btn-booksaw btn-sm">

                                    📩 Send Borrow Request
                                </button>

                            </form>

                        </div>
                    }
                    else
                    {
                        <div class="reservation-card border-start border-warning"
                             style="background:#fffdf5;">

                            <h5 class="fw-bold mb-1"
                                style="font-size:1.1rem;color:#b26a00;">

                                📭 Active Queue Lineup
                            </h5>

                            <p class="text-muted small mb-3">
                                All copies are currently checked out.
                                Reserve your queue position now and
                                get notified once a copy becomes available.
                            </p>

                            <a asp-controller="Reservations"
                               asp-action="Confirm"
                               asp-route-id="@Model.Id"
                               class="btn-reserve-accent btn-sm">

                                📋 Reserve Placement
                            </a>

                        </div>
                    }

                </div>

                <div class="pt-3 border-top d-flex justify-content-between align-items-center">

                    <a asp-action="Index"
                       class="text-decoration-none text-muted tracking-wide small text-uppercase fw-bold">

                        <i class="fa-solid fa-arrow-left me-2"></i>
                        Catalog Grid
                    </a>

                    @if (isLibrarianOrAdmin)
                    {
                        <a asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn-booksaw">

                            <i class="fa-solid fa-pen-to-square me-2"></i>
                            Edit Record
                        </a>
                    }

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/plugins.js"></script>
    <script src="~/js/script.js"></script>
}