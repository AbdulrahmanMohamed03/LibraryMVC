@model Project.Application.ViewModels.Book.BookViewModel

@{
    ViewData["Title"] = "Delete Book";
}

<style>
    h2 { margin-bottom: 16px; }
    hr { border: none; border-top: 1px solid #ddd; margin-bottom: 24px; }

    .alert-danger {
        background: #fdecea; border: 1px solid #e25555;
        color: #a02020; padding: 12px 16px;
        border-radius: 4px; margin-bottom: 24px; font-size: 14px;
    }

    .details-layout {
        display: flex;
        gap: 32px;
        align-items: flex-start;
        margin-bottom: 24px;
    }
    .cover-box img {
        width: 120px;
        border: 1px solid #ddd;
        border-radius: 6px;
    }
    .no-cover-box {
        width: 120px; height: 170px;
        background: #f0f0f0; border: 1px solid #ddd;
        border-radius: 6px; display: flex;
        align-items: center; justify-content: center;
        color: #999; font-size: 12px;
    }

    dl { font-size: 14px; }
    dt { font-weight: 600; color: #333; margin-top: 10px; }
    dd { color: #555; margin: 2px 0 0 0; }

    .form-actions { display: flex; gap: 10px; }
    .btn { padding: 8px 20px; border: none; border-radius: 4px;
           cursor: pointer; text-decoration: none; font-size: 14px; }
    .btn-danger    { background: #e25555; color: #fff; }
    .btn-secondary { background: #9e9e9e; color: #fff; }
</style>

<h2>Delete Book</h2>
<hr />

<div class="alert-danger">
    Are you sure you want to delete this book? This action cannot be undone.
    @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
    {
        <br /><strong>The cover image will also be permanently deleted from the server.</strong>
    }
</div>

<div class="details-layout">

    <div class="cover-box">
        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
        {
            <img src="@Model.CoverImageUrl" alt="@Model.Title cover" />
        }
        else
        {
            <div class="no-cover-box">No Image</div>
        }
    </div>

    <dl>
        <dt>Title</dt>        <dd>@Model.Title</dd>
        <dt>ISBN</dt>         <dd>@Model.ISBN</dd>
        <dt>Author</dt>       <dd>@Model.AuthorName</dd>
        <dt>Category</dt>     <dd>@Model.CategoryName</dd>
        <dt>Total Copies</dt> <dd>@Model.TotalCopies</dd>
        <dt>Available</dt>    <dd>@Model.AvailableCopies</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <div class="form-actions">
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>